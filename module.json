{
  "id": "pf2e-threat-tracker",
  "title": "PF2e Threat Tracker",
  "version": "2.0.0",
  "compatibility": {
    "minimum": "13",
    "verified": "14"
  },
  "description": "<p>PF2e Threat Tracker is a Foundry VTT module that tracks threat/aggro generated by player characters and ally NPCs in the Pathfinder 2e system. Features include per-round threat history, IWR-aware calculations, multi-combat support, and a fully customizable floating panel with 12+ themes.</p>",
  "esmodules": [
    "scripts/main.js"
  ],
  "languages": [
    { "lang": "en", "name": "English", "path": "lang/en.json" },
    { "lang": "es", "name": "Español", "path": "lang/es.json" },
    { "lang": "fr", "name": "Français", "path": "lang/fr.json" }
  ],
  "authors": [
    {
      "name": "Zinneryte",
      "discord": "@zinneryte"
    }
  ],
  "styles": [
    "styles/threat-panel.css"
  ],
  "relationships": {
    "systems": [
      {
        "id": "pf2e",
        "type": "system",
        "compatibility": {
        "minimum": "7.11.3"
        }
      }
    ],
    "recommends": [
      {
        "id": "sequencer",
        "type": "module",
        "compatibility": {}
      }
    ]
  },
  "url": "#{URL}#",
  "manifest": "#{MANIFEST}#",
  "download": "#{DOWNLOAD}#"
}
